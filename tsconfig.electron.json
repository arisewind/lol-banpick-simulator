{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "types": ["node"],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "noImplicitAny": false,
    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": false,
    "outDir": "dist-electron",
    "rootDir": "electron"
  },
  "include": ["electron/**/*"],
  "exclude": ["node_modules"]
}
