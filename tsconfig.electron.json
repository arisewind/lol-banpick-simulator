{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "types": ["node"],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "noImplicitAny": false,
    "strict": false,
    "esModuleInterop": true,
    "allowJs": true,
    "forceConsistentCasingInFileNames": false,
    "outDir": "build/main",
    "rootDir": "src/main"
  },
  "include": ["src/main/**/*"],
  "exclude": ["node_modules"]
}
